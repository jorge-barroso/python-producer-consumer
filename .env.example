###############################
# Kafka Configuration
###############################
KAFKA_NODE_ID=1
KAFKA_NUM_PARTITIONS=6

# Single-node Kafka using KRaft, no ZooKeeper
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093

# Internal, external, and controller listeners
KAFKA_LISTENERS=PLAINTEXT://:9092,HOST://:29092,CONTROLLER://:9093
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092,HOST://localhost:29092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,HOST:PLAINTEXT,CONTROLLER:PLAINTEXT

KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER

# Single-node dev settings
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS=0

# Optional but useful for local dev
KAFKA_AUTO_CREATE_TOPICS_ENABLE="true"

KAFKA_INTERNAL_BOOTSTRAP_SERVERS="kafka:9092"
KAFKA_PRICE_CHANGE_TOPIC="price-change-v1"
KAFKA_IDEMPOTENCE="true"

###############################
# PostgreSQL Configuration
###############################
POSTGRES_HOST="postgres"
#POSTGRES_HOST="127.0.0.1"
POSTGRES_PORT="5432"
POSTGRES_USER="pubsub"
POSTGRES_PASSWORD="adifficultpassword"
POSTGRES_DB="price_change"

###############################
# Producer Configuration
###############################
PRODUCER_PORT=12021
RELOAD="false"
KAFKA_PRODUCER_CLIENT_ID="price_change.producer"

###############################
# Consumer Configuration
###############################
KAFKA_CONSUMER_CLIENT_ID="price-change-audit"